# Copy this file to .env.local and fill in values from the shared Supabase
# project. Never commit .env.local.

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
SUPABASE_SECRET_KEY=sb_secret_...
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Server-only OpenAI key shared by both vision forensics and structured
# claim-specific extraction. Never expose this in frontend code.
OPENAI_API_KEY=your-openai-api-key

# Optional model overrides. The vision model checks visible tampering; the
# receipt model extracts medical, purchase, and Grab-specific fields.
OPENAI_VISION_MODEL=gpt-4o
OPENAI_RECEIPT_MODEL=gpt-5-mini

# Private Supabase Storage bucket containing authentic reference examples.
CLAIM_REFERENCE_BUCKET=claim types
